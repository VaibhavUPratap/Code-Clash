# ── OpenAI ──────────────────────────────────────────────────────────────────
# Required for AI-powered anomaly explanations (GPT-4o-mini or similar).
OPENAI_API_KEY=your_openai_api_key_here

# ── Twitter / X API ─────────────────────────────────────────────────────────
# Required for live tweet metrics in Deep Research (requires Basic or Pro tier).
# Get one from: https://developer.twitter.com/en/portal/dashboard
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here
