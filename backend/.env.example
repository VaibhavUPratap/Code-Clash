# ── Security (auth) ─────────────────────────────────────────────────────────
# Long random string for sessions/JWT signing (≥32 characters recommended).
SECRET_KEY=replace-with-long-random-string
JWT_SECRET=

# ── Gemini ──────────────────────────────────────────────────────────────────
# Required for LLM-backed post-link data, deep research, and anomaly explanations.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash-001

# ── Firebase ────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=code-clash-107
